"""Headless version of Open Lighting Console.

Currently used to run tests on the CoreEngine.
"""

import sys
import time

import numpy as np

sys.path.insert(1, "@pythondir@")

from olc.core import CoreEngine
from olc.core.universe_config import Protocol, UniverseMap

universe_map = UniverseMap(8)
universe_map.enable_protocol(0, Protocol.ARTNET)
universe_map.set_protocols(1, {Protocol.SACN, Protocol.ARTNET})
universe_map.enable_protocol(3, Protocol.SACN)
engine = CoreEngine(
    universe_map, hz=44.0, monitor_port=5555, monitor_fps=15.0, no_listen=True
)
engine.set_channels(0, {k: 0 for k in range(10)})
engine.set_channels(1, {k: 0 for k in range(10)})
engine.set_channels(3, {k: 0 for k in range(10)})
engine.add_fader(0)
engine.add_fader(1)
engine.add_fader(3)
target = np.full(512, 255, dtype=np.uint8)
engine.fade_to(0, target, duration=60)
engine.fade_to(1, target, duration=30)
engine.fade_to(3, target, duration=40)
engine.start()

try:
    while True:
        time.sleep(1.0)
except KeyboardInterrupt:
    print("\nStopping olcd...")
    engine.stop()
